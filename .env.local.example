# EmailJS — créez un compte gratuit sur https://www.emailjs.com/
# puis renseignez ces 3 valeurs (Service ID, Template ID, Public Key).
# Renommez ce fichier en .env.local

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
